<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <solid android:color="@color/water_quick_action_fill_pressed" />
            <stroke android:width="1dp" android:color="@color/water_primary" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <solid android:color="@color/water_quick_action_fill" />
            <stroke android:width="1dp" android:color="@color/water_card_stroke" />
        </shape>
    </item>
</selector>
