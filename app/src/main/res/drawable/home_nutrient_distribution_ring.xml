<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 背景圆环 -->
    <item>
        <rotate
            android:fromDegrees="-90"
            android:pivotX="50%"
            android:pivotY="50%"
            android:toDegrees="-90">
            <shape
                android:innerRadiusRatio="3"
                android:shape="ring"
                android:thicknessRatio="8"
                android:useLevel="true">
                <solid android:color="@color/background_gray" />
            </shape>
        </rotate>
    </item>
    
    <!-- 碳水化合物部分 (0-50%) -->
    <item>
        <rotate
            android:fromDegrees="-90"
            android:pivotX="50%"
            android:pivotY="50%"
            android:toDegrees="-90">
            <shape
                android:innerRadiusRatio="3"
                android:shape="ring"
                android:thicknessRatio="8"
                android:useLevel="true">
                <solid android:color="@color/carb_color" />
            </shape>
        </rotate>
    </item>
    
    <!-- 蛋白质部分 (50-75%) -->
    <item>
        <clip android:clipOrientation="horizontal" android:gravity="left">
            <rotate
                android:fromDegrees="-90"
                android:pivotX="50%"
                android:pivotY="50%"
                android:toDegrees="-90">
                <shape
                    android:innerRadiusRatio="3"
                    android:shape="ring"
                    android:thicknessRatio="8"
                    android:useLevel="true">
                    <solid android:color="@color/protein_color" />
                </shape>
            </rotate>
        </clip>
    </item>
    
    <!-- 脂肪部分 (75-100%) -->
    <item>
        <clip android:clipOrientation="horizontal" android:gravity="left">
            <rotate
                android:fromDegrees="-90"
                android:pivotX="50%"
                android:pivotY="50%"
                android:toDegrees="-90">
                <shape
                    android:innerRadiusRatio="3"
                    android:shape="ring"
                    android:thicknessRatio="8"
                    android:useLevel="true">
                    <solid android:color="@color/fat_color" />
                </shape>
            </rotate>
        </clip>
    </item>
</layer-list>