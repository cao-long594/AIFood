<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <TextView
        android:id="@+id/tv_weekday"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/home_text_tertiary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_day"
        android:layout_width="40dp"
        android:layout_height="44dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/meal_calendar_circle_unselected"
        android:gravity="center"
        android:textColor="@color/home_text_secondary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <View
        android:id="@+id/view_past_dot"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/meal_calendar_past_dot"
        android:visibility="invisible" />
</LinearLayout>
