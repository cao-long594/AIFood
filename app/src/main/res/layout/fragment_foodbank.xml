<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fragment_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_page_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/ui_page_horizontal"
        android:paddingTop="@dimen/ui_page_top"
        android:paddingEnd="@dimen/ui_page_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/foodbank_title"
            android:textColor="@color/home_text_primary"
            android:textSize="@dimen/ui_text_title"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/foodbank_subtitle"
            android:textColor="@color/home_text_secondary"
            android:textSize="@dimen/ui_text_caption" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/home_surface"
            app:cardCornerRadius="@dimen/ui_card_radius_md"
            app:cardElevation="0dp">

            <SearchView
                android:id="@+id/search_view"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/meal_search_background"
                android:iconifiedByDefault="false"
                android:queryHint="@string/search_hint_food" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tv_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:text="@string/foodbank_empty_state"
            android:textColor="@color/home_text_secondary"
            android:textSize="@dimen/ui_text_body"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_food"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="132dp" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_add_food"
        android:layout_width="@dimen/ui_fab_size"
        android:layout_height="@dimen/ui_fab_size"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/ui_fab_margin"
        android:layout_marginBottom="@dimen/ui_fab_margin"
        android:contentDescription="@string/fab_add_food_desc"
        android:src="@drawable/ic_plus_24"
        app:backgroundTint="@color/primary_color"
        app:borderWidth="0dp"
        app:elevation="0dp"
        app:maxImageSize="24dp"
        app:tint="@color/white" />

</FrameLayout>