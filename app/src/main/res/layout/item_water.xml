<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/water_record_item_bg"
    android:gravity="center_vertical"
    android:minHeight="68dp"
    android:orientation="horizontal"
    android:paddingStart="14dp"
    android:paddingTop="12dp"
    android:paddingEnd="14dp"
    android:paddingBottom="12dp">

    <View
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/water_record_dot_bg" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_water_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/water_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="07:38" />

        <TextView
            android:id="@+id/tv_water_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="已记录"
            android:textColor="@color/water_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_water_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:textColor="@color/water_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="180 ml" />

    <TextView
        android:id="@+id/btn_delete_water"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/water_record_delete_bg"
        android:gravity="center"
        android:text="×"
        android:textColor="@color/water_text_secondary"
        android:textSize="20sp"
        android:textStyle="bold" />
</LinearLayout>
