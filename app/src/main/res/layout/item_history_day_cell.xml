<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="38dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <View
        android:id="@+id/view_week_band"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_day_number"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_gravity="center"
        android:background="@drawable/history_day_normal_bg"
        android:gravity="center"
        android:textColor="@color/home_text_primary"
        android:textSize="14sp" />

    <View
        android:id="@+id/view_today_dot"
        android:layout_width="4dp"
        android:layout_height="4dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="4dp"
        android:background="@drawable/history_today_dot"
        android:visibility="gone" />

</FrameLayout>
