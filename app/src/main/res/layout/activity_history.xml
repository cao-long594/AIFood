<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_page_background"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingTop="14dp"
    android:paddingEnd="14dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btn_history_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="@string/history_back"
            android:focusable="true"
            android:padding="6dp"
            android:src="@drawable/water_3_calendar_ic_left"
            app:tint="@color/home_text_primary" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_history_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/home_text_primary"
        android:textSize="26sp" />

    <TextView
        android:id="@+id/tv_history_range"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/home_text_primary"
        android:textSize="17sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/history_tab_container_bg"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/tv_history_tab_day"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/history_tab_selected_bg"
            android:gravity="center"
            android:text="@string/history_day_tab"
            android:textColor="@color/home_text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tv_history_tab_week"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/history_tab_unselected_bg"
            android:gravity="center"
            android:text="@string/history_week_tab"
            android:textColor="@color/home_text_secondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tv_history_tab_month"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/history_tab_unselected_bg"
            android:gravity="center"
            android:text="@string/history_month_tab"
            android:textColor="@color/home_text_secondary"
            android:textSize="15sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_history_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="12dp" />
</LinearLayout>
